{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Compile & Run C++",
            "type": "shell",
            "command": "/bin/zsh",
            "args": [
                "-c",
                "/opt/homebrew/bin/g++-15 -std=c++17 -Wall \"${file}\" -o \"${fileDirname}/${fileBasenameNoExtension}\" && \"${fileDirname}/${fileBasenameNoExtension}\" < \"${fileDirname}/input.txt\" > \"${fileDirname}/output.txt\""
            ],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}